# Optional Docker Compose LAN access settings.
# Copy this file to .env and replace 192.168.1.20 with the IPv4 address
# of the development PC before running docker compose up --build.

LAN_HOST=192.168.1.20

# Optional direct overrides. These are useful when you do not want to rely
# on LAN_HOST-based defaults.
# NEXT_PUBLIC_CHAT_SERVER_URL=http://192.168.1.20:4000
# CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.20:3000
